[Interface]
PrivateKey = YOUR_CLIENT_PRIVATE_KEY_HERE
Address = 10.0.0.2/32
DNS = 1.1.1.1

# Disable IPv6 on Wi-Fi while the tunnel is up, so nothing leaks outside the
# encrypted tunnel — all traffic goes IPv4 through WireGuard. Standard VPN hygiene.
PostUp = /usr/sbin/networksetup -setv6off Wi-Fi
PostDown = /usr/sbin/networksetup -setv6automatic Wi-Fi

[Peer]
PublicKey = YOUR_SERVER_PUBLIC_KEY_HERE
Endpoint = YOUR_SERVER_IP:51820
AllowedIPs = 0.0.0.0/0
PersistentKeepalive = 25
