#!/bin/bash
  export PATH="/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:$PATH"

  # ── Detect Homebrew prefix (Apple Silicon vs Intel) ──
  # Apple Silicon: /opt/homebrew | Intel: /usr/local
  if [ "$(uname -m)" = "arm64" ]; then
      BREW_PREFIX="/opt/homebrew"
  else
      BREW_PREFIX="/usr/local"
  fi
  WG_BIN="$BREW_PREFIX/bin/wg"

  WG_USAGE_LOG="/var/log/wg-usage.log"

  # ── ANSI color codes ──
  GRN=$'\033[1;92m'  # bold bright green → incoming ↓
  RED=$'\033[1;91m'  # bold bright red   → outgoing ↑
  PUR=$'\033[95m'    # magenta/purple    → Live, All time
  CYN=$'\033[96m'    # cyan              → Today, Yesterday
  LGY=$'\033[37m'    # light grey        → session labels
  RST=$'\033[0m'     # reset

  # ── Convert bytes to human readable ──
  human_readable() {
      local bytes=$1
      if [ "$bytes" -ge 1073741824 ]; then
          printf "%.2f GB" $(echo "scale=2; $bytes/1073741824" | bc)
      elif [ "$bytes" -ge 1048576 ]; then
          printf "%.2f MB" $(echo "scale=2; $bytes/1048576" | bc)
      elif [ "$bytes" -ge 1024 ]; then
          printf "%.2f KB" $(echo "scale=2; $bytes/1024" | bc)
      else
          printf "%d B" "$bytes"
      fi
  }

  # ── Get current live session ──
  get_live() {
      DUMP=$(sudo $WG_BIN show all dump 2>/dev/null | awk 'NR==2 {print $7, $8}')
      CRX=0
      CTX=0
      TUNNEL_UP=0
      if [ -n "$DUMP" ]; then
          TUNNEL_UP=1
          CRX=$(echo "$DUMP" | cut -d' ' -f1)
          CTX=$(echo "$DUMP" | cut -d' ' -f2)
      fi
  }

  # ── Parse log file (terminal mode only) ──
  parse_log() {
      TOTAL_RX=0
      TOTAL_TX=0
      CURRENT_DATE=""
      DAY_RX=0
      DAY_TX=0
      SESSION_NUM=0

      while IFS= read -r line; do
          DATE=$(echo "$line" | cut -d' ' -f1)
          TIME=$(echo "$line" | cut -d' ' -f2)
          RX=$(echo "$line" | grep -o 'rx:[0-9]*' | cut -d: -f2)
          TX=$(echo "$line" | grep -o 'tx:[0-9]*' | cut -d: -f2)

          if [ "$DATE" != "$CURRENT_DATE" ]; then
              if [ -n "$CURRENT_DATE" ]; then
                  printf "   Day total              %s ↓   %s ↑\n\n" "$(human_readable $DAY_RX)" "$(human_readable $DAY_TX)"
              fi
              CURRENT_DATE="$DATE"
              DAY_RX=0
              DAY_TX=0
              SESSION_NUM=0
              echo " $DATE"
          fi

          SESSION_NUM=$((SESSION_NUM + 1))
          DAY_RX=$((DAY_RX + RX))
          DAY_TX=$((DAY_TX + TX))
          TOTAL_RX=$((TOTAL_RX + RX))
          TOTAL_TX=$((TOTAL_TX + TX))

          printf "   Session %-2s  %s   %s ↓   %s ↑\n" "$SESSION_NUM" "$TIME" "$(human_readable $RX)" "$(human_readable $TX)"

      done < "$WG_USAGE_LOG"

      if [ -n "$CURRENT_DATE" ]; then
          DAY_RX=$((DAY_RX + CRX))
          DAY_TX=$((DAY_TX + CTX))
          printf "   Day total              %s ↓   %s ↑\n" "$(human_readable $DAY_RX)" "$(human_readable $DAY_TX)"
      fi

      TOTAL_RX=$((TOTAL_RX + CRX))
      TOTAL_TX=$((TOTAL_TX + CTX))
  }

  # ── Terminal mode ──
  terminal_mode() {
      get_live

      echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
      echo "          WireGuard Usage Stats"
      echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
      if [ "$TUNNEL_UP" -eq 1 ]; then
          printf " Current session:  %s ↓   %s ↑   (live)\n\n" "$(human_readable $CRX)" "$(human_readable $CTX)"
      else
          echo " Tunnel: offline"
          echo ""
      fi
      parse_log
      echo ""
      echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
      printf " All time total:       %s ↓   %s ↑\n" "$(human_readable $TOTAL_RX)" "$(human_readable $TOTAL_TX)"
      echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  }

  # ── Menu bar mode ──
  bar_mode() {
      get_live
      TODAY=$(date '+%Y-%m-%d')
      YESTERDAY=$(date -v-1d '+%Y-%m-%d')

      # ── Read all sessions into arrays ──
      declare -a LOG_DATE LOG_TIME LOG_RX LOG_TX
      IDX=0
      TOTAL_RX=0
      TOTAL_TX=0

      while IFS= read -r line; do
          LOG_DATE[$IDX]=$(echo "$line" | cut -d' ' -f1)
          LOG_TIME[$IDX]=$(echo "$line" | cut -d' ' -f2)
          LOG_RX[$IDX]=$(echo "$line" | grep -o 'rx:[0-9]*' | cut -d: -f2)
          LOG_TX[$IDX]=$(echo "$line" | grep -o 'tx:[0-9]*' | cut -d: -f2)
          TOTAL_RX=$((TOTAL_RX + LOG_RX[$IDX]))
          TOTAL_TX=$((TOTAL_TX + LOG_TX[$IDX]))
          IDX=$((IDX + 1))
      done < "$WG_USAGE_LOG"

      TOTAL_RX=$((TOTAL_RX + CRX))
      TOTAL_TX=$((TOTAL_TX + CTX))

      # ── Menu bar line ──
      if [ "$TUNNEL_UP" -eq 1 ]; then
          echo "WG ${GRN}●${RST}  ↓$(human_readable $CRX)  ↑$(human_readable $CTX) | ansi=true"
      else
          echo "WG ○  offline | color=#FF453A"
      fi

      echo "---"

      # ── Live: magenta label ──
      if [ "$TUNNEL_UP" -eq 1 ]; then
          echo "🟢  ${PUR}Live${RST}   ${GRN}↓$(human_readable $CRX)${RST}   ${RED}↑$(human_readable $CTX)${RST} | ansi=true"
          echo "-- 🔗 Tunnel active | color=#888888"
      else
          echo "🔴  ${RED}Tunnel offline${RST} | ansi=true"
          echo "-- ⚠️  Hotspot not connected | color=#888888"
      fi

      echo "---"

      # ── Get unique dates ──
      declare -a UNIQUE_DATES
      PREV_DATE=""
      for ((i=0; i<IDX; i++)); do
          if [ "${LOG_DATE[$i]}" != "$PREV_DATE" ]; then
              UNIQUE_DATES+=("${LOG_DATE[$i]}")
              PREV_DATE="${LOG_DATE[$i]}"
          fi
      done

      NUM_DATES=${#UNIQUE_DATES[@]}

      # ── Output dates newest first ──
      for ((d=NUM_DATES-1; d>=0; d--)); do
          DATE="${UNIQUE_DATES[$d]}"

          declare -a D_TIME D_RX D_TX
          D_COUNT=0
          DAY_RX=0
          DAY_TX=0

          for ((i=0; i<IDX; i++)); do
              if [ "${LOG_DATE[$i]}" = "$DATE" ]; then
                  D_TIME[$D_COUNT]="${LOG_TIME[$i]}"
                  D_RX[$D_COUNT]="${LOG_RX[$i]}"
                  D_TX[$D_COUNT]="${LOG_TX[$i]}"
                  DAY_RX=$((DAY_RX + LOG_RX[$i]))
                  DAY_TX=$((DAY_TX + LOG_TX[$i]))
                  D_COUNT=$((D_COUNT + 1))
              fi
          done

          if [ "$DATE" = "$TODAY" ]; then
              DAY_RX=$((DAY_RX + CRX))
              DAY_TX=$((DAY_TX + CTX))
          fi

          # ── TODAY: cyan header, latest 4 sessions ──
          if [ "$DATE" = "$TODAY" ]; then
              echo "📅  ${CYN}Today${RST} | ansi=true"

              LIMIT=4
              SHOW_FROM=$((D_COUNT - LIMIT))
              [ $SHOW_FROM -lt 0 ] && SHOW_FROM=0
              HIDDEN=$SHOW_FROM

              # Latest 4 newest first
              for ((i=D_COUNT-1; i>=SHOW_FROM; i--)); do
                  SNUM=$((i + 1))
                  echo "   ${LGY}Session $SNUM  ${D_TIME[$i]}${RST}   ${GRN}↓$(human_readable ${D_RX[$i]})${RST}   ${RED}↑$(human_readable ${D_TX[$i]})${RST} | ansi=true"
              done

              # Earlier sessions collapsed
              if [ $HIDDEN -gt 0 ]; then
                  echo "   ▸ $HIDDEN earlier session(s) | color=#888888"
                  for ((i=HIDDEN-1; i>=0; i--)); do
                      SNUM=$((i + 1))
                      echo "-- Session $SNUM  ${D_TIME[$i]}   ${GRN}↓$(human_readable ${D_RX[$i]})${RST}   ${RED}↑$(human_readable ${D_TX[$i]})${RST} | color=#888888 ansi=true"
                  done
              fi

              echo "   ${CYN}📊 Day total   ${GRN}↓$(human_readable $DAY_RX)${RST}   ${RED}↑$(human_readable $DAY_TX)${RST} | ansi=true"
              echo "-- 📊 Includes live session | color=#888888"

          # ── PREVIOUS DAYS: cyan header, collapsed ──
          else
              if [ "$DATE" = "$YESTERDAY" ]; then
                  LABEL="Yesterday ($DATE)"
              else
                  LABEL="$DATE"
              fi

              echo "${CYN}📅  $LABEL${RST}   ${GRN}↓$(human_readable $DAY_RX)${RST}   ${RED}↑$(human_readable $DAY_TX)${RST} | ansi=true"

              for ((i=D_COUNT-1; i>=0; i--)); do
                  SNUM=$((i + 1))
                  echo "-- Session $SNUM  ${D_TIME[$i]}   ${GRN}↓$(human_readable ${D_RX[$i]})${RST}   ${RED}↑$(human_readable ${D_TX[$i]})${RST} | color=#888888 ansi=true"
              done
              echo "-- ${CYN}📊 Day total   ${GRN}↓$(human_readable $DAY_RX)${RST}   ${RED}↑$(human_readable $DAY_TX)${RST} | ansi=true"
          fi

          echo "---"
          unset D_TIME D_RX D_TX
      done

      # ── All time: magenta label ──
      echo "${PUR}🌐  All time${RST}   ${GRN}↓$(human_readable $TOTAL_RX)${RST}   ${RED}↑$(human_readable $TOTAL_TX)${RST} | ansi=true"
      echo "-- 📋 $IDX sessions logged | color=#888888"
  }

  # ── Entry point ──
  if [ "$1" = "--bar" ]; then
      bar_mode
  else
      terminal_mode
  fi
